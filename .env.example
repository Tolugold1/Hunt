# Database
DATABASE_URL="postgresql://user:password@localhost:5432/hunt"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Google OAuth (for Gmail mailbox + Google Sign-In)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Claude API
ANTHROPIC_API_KEY=""


# Redis (BullMQ)
REDIS_URL="redis://localhost:6379"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# AI Provider — set to: claude | openai | gemini (default: claude)
LLM_PROVIDER="claude"

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=""

# Google Gemini (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=""

# Cloudinary (replaces S3/R2 for document storage)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
